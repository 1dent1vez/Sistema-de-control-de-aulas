APP_NAME=SistemaControlAulas
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_MX

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_LEVEL_SAM_AUTH=debug


DB_CONNECTION=mysql
DB_FOREIGN_KEYS=true
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gama_control_aulas
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=30
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@controlaulas.edu.mx"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# GAMA - CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# SAM Auth
SAM_URL=
SAM_SYSTEM_URL=
SAM_TIMEOUT=5
SAM_CONNECT_TIMEOUT=3
SAM_MOCK_ENABLED=false
SAM_VERIFY_SSL=false
SANCTUM_STATEFUL_DOMAINS=
AUTH_RATE_LIMIT=10

# SAM Database Connection
SAM_DB_HOST=127.0.0.1
SAM_DB_PORT=3306
SAM_DB_DATABASE=sam
SAM_DB_USERNAME=root
SAM_DB_PASSWORD=

# GAMA - Rate Limiting
API_RATE_LIMIT=60
API_RATE_LIMIT_AUTH=10

VITE_APP_NAME="${APP_NAME}"
